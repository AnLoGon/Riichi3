<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- 3D Bevel/Drop Shadow Layer -->
    <item
        android:width="52dp"
        android:height="68dp"
        android:top="3dp"
        android:gravity="center">
        <shape android:shape="rectangle">
            <solid android:color="#0F172A" />
            <corners android:radius="8dp" />
        </shape>
    </item>

    <!-- Physical White Tile Card Base -->
    <item
        android:width="52dp"
        android:height="68dp"
        android:gravity="center">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="8dp" />
            <stroke android:width="1.5dp" android:color="#CBD5E1" />
        </shape>
    </item>
    
    <!-- Mahjong Pin 3 (3 Circles) Symbol -->
    <item
        android:width="44dp"
        android:height="60dp"
        android:gravity="center">
        <bitmap
            android:src="@drawable/pin3"
            android:gravity="center" />
    </item>
    
</layer-list>